# ------ ALIASES ------
# git
alias ga="git add"
alias gaa="git add ."
alias gcm="git commit -m"
alias gca="git commit --amend"
alias gb="git branch"
alias gc="git switch"
alias gp="git pull"
alias gP="git push"
alias gf="git fetch"
alias gpnv="git push --no-verify"
alias gps="git push --set-upstream origin"
alias gpnvs="git push --no-verify --set-upstream origin"
alias gpod="git pull origin develop"
alias gpom="git pull origin main"

# nav
alias d="cd /$HOME/Developer/wuguishifu/universe"
alias g="cd /$HOME/Developer"
alias la="ls -a"

# k8s
alias k="kubectl"

# node tooling
alias nx="pnpm nx"
alias moon="pnpm moon"
alias turbo="pnpm turbo"

